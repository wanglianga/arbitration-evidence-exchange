# 应用配置
APP_NAME=仲裁证据交换服务
DEBUG=true

# 数据库连接
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/arbitration_evidence

# JWT 配置
SECRET_KEY=your-secret-key-change-in-production-please-use-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 文件上传配置
UPLOAD_DIR=./uploads
CHUNK_DIR=./uploads/chunks
# 最大上传文件 1GB
MAX_UPLOAD_SIZE=1073741824
# 分块大小 5MB
CHUNK_SIZE=5242880
